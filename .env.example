# Generated by VPS-CODE-BOT installer
# Edit manually or run: npm run setup

# ━━━ Network Configuration ━━━
# Choose ONE of the following:

# Option 1: Custom Domain (with Caddy + SSL)
DOMAIN=your-domain.com

# Option 2: IP Address + Port
# IP_ADDRESS=192.168.1.100
# PORT=8080

# ━━━ Storage ━━━
PROJECTS_DIR=/home/your_user/vps-code-bot-projects

# ━━━ Claude Code CLI (REQUIRED) ━━━
CLAUDE_CLI=/path/to/claude-code/cli.js
NODE_BIN=/usr/bin/node

# ━━━ Telegram Bot (OPTIONAL) ━━━
# Leave empty to skip Telegram integration
# BOT_TOKEN=your_telegram_bot_token
# CHAT_ID=your_chat_id

# ━━━ OpenRouter API (OPTIONAL) ━━━
# For using alternative LLM models
# OPENROUTER_API_KEY=

# ━━━ System Configuration ━━━
CADDY_ADMIN_URL=http://localhost:2019
DOCKER_SOCKET=/var/run/docker.sock
